# ── Supabase ─────────────────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Resend (email) ───────────────────────────────────────────────────────
# https://resend.com/api-keys — for production use a verified domain sender.
RESEND_API_KEY=
EMAIL_FROM=Attendly <onboarding@resend.dev>

# ── App ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Event & payment details (shown in emails and on the portal) ─────────
EVENT_NAME=Alumni Reunion 2026
TICKET_PRICE=Rs. 5,000
BANK_NAME=Your Bank
BANK_ACCOUNT_NAME=Event Committee
BANK_ACCOUNT_NUMBER=000-000-0000
BANK_BRANCH=Main Branch
